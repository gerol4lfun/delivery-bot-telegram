# Скопируй в .env и подставь свои значения. В GitHub не коммитить!

# Telegram (получить у @BotFather)
TELEGRAM_BOT_TOKEN=

# Supabase (Project Settings → API: URL и service_role key)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Твой Telegram user id (узнать у @userinfobot). Если не указать — бот отвечает всем.
ADMIN_USER_ID=

# Только для Vercel: любой пароль для страницы включения вебхука (придумай сам)
WEBHOOK_SECRET=
